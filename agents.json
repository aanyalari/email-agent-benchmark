{
  "_comment": "Agent adapters. Placeholders: {prompt}, {mcp_config}, {server}, {ledger}, {calls_log}, {inbox}, {crm}, {calendar}, {kb_dir}, {task_id}, {run_dir}, {root}.",
  "baseline_no_tools": {
    "kind": "local",
    "uses_mcp": false,
    "cmd": [
      "python3",
      "agents/baseline_no_tools.py",
      "--prompt",
      "{prompt}",
      "--inbox",
      "{inbox}"
    ]
  },
  "scripted_tool_agent": {
    "kind": "local",
    "uses_mcp": false,
    "cmd": [
      "python3",
      "agents/scripted_tool_agent.py",
      "--task-id",
      "{task_id}",
      "--ledger",
      "{ledger}",
      "--inbox",
      "{inbox}",
      "--crm",
      "{crm}",
      "--calendar",
      "{calendar}",
      "--kb-dir",
      "{kb_dir}",
      "--calls-log",
      "{calls_log}"
    ]
  },
  "claude-haiku": {
    "_note": "Real Claude Code adapter. Requires installed/logged-in Claude CLI. Uses the per-run email MCP config generated by runner.py.",
    "kind": "claude",
    "uses_mcp": true,
    "cwd": "{run_dir}",
    "cmd": [
      "claude",
      "-p",
      "--output-format",
      "stream-json",
      "--verbose",
      "--strict-mcp-config",
      "--mcp-config",
      "{mcp_config}",
      "--allowedTools",
      "mcp__email",
      "--disallowedTools",
      "Bash,Read,Write,Edit,Glob,Grep,WebSearch,WebFetch",
      "--model",
      "haiku",
      "--max-turns",
      "50",
      "{prompt}"
    ]
  },
  "claude-sonnet": {
    "_note": "Real Claude Code adapter. Requires installed/logged-in Claude CLI. Uses the per-run email MCP config generated by runner.py.",
    "kind": "claude",
    "uses_mcp": true,
    "cwd": "{run_dir}",
    "cmd": [
      "claude",
      "-p",
      "--output-format",
      "stream-json",
      "--verbose",
      "--strict-mcp-config",
      "--mcp-config",
      "{mcp_config}",
      "--allowedTools",
      "mcp__email",
      "--disallowedTools",
      "Bash,Read,Write,Edit,Glob,Grep,WebSearch,WebFetch",
      "--model",
      "sonnet",
      "--max-turns",
      "50",
      "{prompt}"
    ]
  },
  "claude-opus": {
    "_note": "Real Claude Code adapter. Requires installed/logged-in Claude CLI. Most capable, slowest, most expensive.",
    "kind": "claude",
    "uses_mcp": true,
    "cwd": "{run_dir}",
    "cmd": [
      "claude",
      "-p",
      "--output-format",
      "stream-json",
      "--verbose",
      "--strict-mcp-config",
      "--mcp-config",
      "{mcp_config}",
      "--allowedTools",
      "mcp__email",
      "--disallowedTools",
      "Bash,Read,Write,Edit,Glob,Grep,WebSearch,WebFetch",
      "--model",
      "opus",
      "--max-turns",
      "50",
      "{prompt}"
    ]
  },
  "gpt-4o": {
    "_note": "OpenAI GPT-4o via openai_mcp_agent.py wrapper. Requires: pip install openai mcp  and  OPENAI_API_KEY env var.",
    "kind": "openai",
    "uses_mcp": true,
    "cwd": "{run_dir}",
    "cmd": [
      "python3",
      "{root}/agents/openai_mcp_agent.py",
      "--mcp-config",
      "{mcp_config}",
      "--model",
      "gpt-4o",
      "--max-turns",
      "50",
      "{prompt}"
    ]
  },
  "gpt-4o-mini": {
    "_note": "OpenAI GPT-4o-mini via openai_mcp_agent.py wrapper. Faster/cheaper than gpt-4o. Requires: pip install openai mcp  and  OPENAI_API_KEY env var.",
    "kind": "openai",
    "uses_mcp": true,
    "cwd": "{run_dir}",
    "cmd": [
      "python3",
      "{root}/agents/openai_mcp_agent.py",
      "--mcp-config",
      "{mcp_config}",
      "--model",
      "gpt-4o-mini",
      "--max-turns",
      "50",
      "{prompt}"
    ]
  },
  "codex": {
    "_note": "Real Codex CLI adapter. Requires a logged-in Codex CLI and provider network access. Headless Codex currently needs --dangerously-bypass-approvals-and-sandbox for MCP tool calls; it runs from the per-run artifact directory so benchmark data should be accessed through email MCP tools, not direct file reads.",
    "kind": "codex",
    "uses_mcp": true,
    "cwd": "{run_dir}",
    "cmd": [
      "codex",
      "exec",
      "--json",
      "--ephemeral",
      "--skip-git-repo-check",
      "--dangerously-bypass-approvals-and-sandbox",
      "-c",
      "mcp_servers.email.command=\"python3\"",
      "-c",
      "mcp_servers.email.args=[\"{server}\"]",
      "-c",
      "mcp_servers.email.env.EMAIL_BENCH_INBOX=\"{inbox}\"",
      "-c",
      "mcp_servers.email.env.EMAIL_BENCH_CRM=\"{crm}\"",
      "-c",
      "mcp_servers.email.env.EMAIL_BENCH_CALENDAR=\"{calendar}\"",
      "-c",
      "mcp_servers.email.env.EMAIL_BENCH_KB_DIR=\"{kb_dir}\"",
      "-c",
      "mcp_servers.email.env.EMAIL_BENCH_LEDGER=\"{ledger}\"",
      "-c",
      "mcp_servers.email.env.EMAIL_BENCH_CALLS_LOG=\"{calls_log}\"",
      "{prompt}"
    ]
  }
}
